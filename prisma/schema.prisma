generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String
  content      String?
  tags         String[] @default([])
  images       String[] @default([])
  thumbnailUrl String?
  category     String?
  published    Boolean  @default(false)

  // ==== SEO fields ====
  metaTitle       String?
  metaDescription String?
  metaKeywords    String[] @default([])
  canonicalUrl    String?
  ogImage         String?
  publishedAt     DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([published, updatedAt])
  @@index([slug])
}

// --- Post & Category ---
model Post {
  id      String  @id @default(cuid())
  title   String
  slug    String  @unique
  excerpt String? @db.Text
  content String  @db.Text

  author   User   @relation(fields: [authorId], references: [id])
  authorId String

  // ⬇⬇⬇ Tambahan supaya cocok dengan actions.ts & page.tsx
  coverUrl        String?
  metaTitle       String?
  metaDescription String?
  metaKeywords    String[] // Postgres array of text
  tags            String[] @db.Text // (opsional: boleh dibiarkan seperti ini kalau sudah existing)

  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  // Relasi kategori (implicit many-to-many)
  categories Category[]
}

model Category {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  posts Post[] // lawan dari Post.categories
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(USER)
  posts     Post[]
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}

model CvRequest {
  id         String    @id @default(cuid())
  email      String
  source     String
  company    String?
  fullName   String
  phone      String?
  message    String?
  token      String    @unique
  verified   Boolean   @default(false)
  approvedBy String?
  approvedAt DateTime?
  createdAt  DateTime  @default(now())
}

model SiteSetting {
  id           String   @id @default("singleton")
  defaultLang  String   @default("id")
  defaultTheme String   @default("system")
  seoTitle     String?
  seoDesc      String?
  i18n         Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
